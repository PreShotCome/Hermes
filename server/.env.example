# Server-side shared secret — match the value in lib/config.dart (apiKey).
HERMES_API_KEY=hermes-dev-key-change-me

# Optional: The Odds API key. Leave blank to use mocked odds data.
# Get one at https://the-odds-api.com/
ODDS_API_KEY=

# Optional: SharpAPI key (https://sharpapi.io). When set, Hermes pulls
# positive-EV opportunities from SharpAPI (Pinnacle-de-vigged fair line
# vs FanDuel posted price) instead of running the local Elo model.
# Free tier = 12 req/min, plenty at the default 5-min scan interval.
SHARP_API_KEY=sk_live_SvqknjuL4x2kpbuHHvvnhv

# Optional: Anthropic API key for the Oracle chat. Leave blank to disable.
ANTHROPIC_API_KEY=

# Starting bankroll for paper-mode tracking (dollars).
STARTING_BANKROLL=1000

# Scan interval in seconds.
SCAN_INTERVAL_SECONDS=300
